# ── Required ──────────────────────────────────────────────────────────────────
PALACE_ID=yourname                      # unique slug for your palace
API_TOKEN=change-me-to-a-long-secret    # bearer token for API access
POSTGRES_PASSWORD=change-me             # postgres password

# ── LLM — Embedding ───────────────────────────────────────────────────────────
# Needs an OpenAI-compatible /v1/embeddings endpoint
# Ollama (local, free): ollama pull nomic-embed-text
LOCIGRAM_EMBED_URL=http://localhost:11434/v1
LOCIGRAM_EMBED_MODEL=nomic-embed-text
LOCIGRAM_EMBED_KEY=                     # leave blank for Ollama / local

# OpenAI alternative:
# LOCIGRAM_EMBED_URL=https://api.openai.com/v1
# LOCIGRAM_EMBED_MODEL=text-embedding-3-small
# LOCIGRAM_EMBED_KEY=sk-...

# ── LLM — Extraction (entity parsing from raw content) ────────────────────────
# Needs an OpenAI-compatible /v1/chat/completions endpoint
# Ollama (local, free): ollama pull qwen2.5:7b
LOCIGRAM_EXTRACT_URL=http://localhost:11434/v1
LOCIGRAM_EXTRACT_MODEL=qwen2.5:7b
LOCIGRAM_EXTRACT_KEY=                   # leave blank for Ollama / local
LOCIGRAM_EXTRACT_NO_THINK=false        # set true for Qwen3 models — disables chain-of-thought, faster + fewer tokens

# OpenAI alternative:
# LOCIGRAM_EXTRACT_URL=https://api.openai.com/v1
# LOCIGRAM_EXTRACT_MODEL=gpt-4o-mini
# LOCIGRAM_EXTRACT_KEY=sk-...

# ── LLM — Summarization / Truth (optional, falls back to extract) ─────────────
# Use a larger model here if you want better truth synthesis
# LOCIGRAM_SUMMARY_URL=https://api.openai.com/v1
# LOCIGRAM_SUMMARY_MODEL=gpt-4o
# LOCIGRAM_SUMMARY_KEY=sk-...
# LOCIGRAM_SUMMARY_NO_THINK=false      # set true for Qwen3 summary models

# ── QuickBooks Online (optional — activate by setting all 4 required vars) ────
# LOCIGRAM_QBO_CLIENT_ID=your-client-id
# LOCIGRAM_QBO_CLIENT_SECRET=your-client-secret
# LOCIGRAM_QBO_REALM_ID=your-company-id        # from QBO URL: /app/homepage?realmId=XXXXXXX
# LOCIGRAM_QBO_REFRESH_TOKEN=your-refresh-token
# LOCIGRAM_QBO_ACCESS_TOKEN=                   # optional — refreshed automatically
# LOCIGRAM_QBO_BASE_URL=                       # optional — defaults to https://quickbooks.api.intuit.com
# LOCIGRAM_QBO_MINOR_VERSION=                  # optional — e.g. 65

# ── Connectors — add whichever you have credentials for ──────────────────────
# Locigram auto-detects which connectors to enable based on what's set here.
# Leave a connector's vars blank/absent to skip it. Webhook is always enabled.

# Microsoft 365 (email + Teams)
# LOCIGRAM_M365_TENANT_ID=
# LOCIGRAM_M365_CLIENT_ID=
# LOCIGRAM_M365_CLIENT_SECRET=
# LOCIGRAM_M365_MAILBOXES=you@company.com,support@company.com

# HaloPSA
# LOCIGRAM_HALOPSA_URL=https://yourinstance.halopsa.com
# LOCIGRAM_HALOPSA_CLIENT_ID=
# LOCIGRAM_HALOPSA_CLIENT_SECRET=

# NinjaOne
# LOCIGRAM_NINJA_CLIENT_ID=
# LOCIGRAM_NINJA_CLIENT_SECRET=

# Gmail
# LOCIGRAM_GMAIL_CLIENT_ID=
# LOCIGRAM_GMAIL_CLIENT_SECRET=
# LOCIGRAM_GMAIL_REFRESH_TOKEN=

# ── Memory intelligence (temporal decay + co-retrieval clustering) ────────────
LOCIGRAM_DECAY_FACTOR=0.6              # λ exponent in inverse power-law decay formula
LOCIGRAM_DECAY_HOT_THRESHOLD=0.3       # access_score below this → demote hot to warm
LOCIGRAM_DECAY_WARM_THRESHOLD=0.1      # access_score below this → demote warm to cold
LOCIGRAM_DECAY_NOISE_THRESHOLD=0.05    # access_score below this → queue cold for LLM re-assessment
LOCIGRAM_CLUSTER_MIN_COOCCURRENCE=5    # min co-retrievals in window to flag as cluster_candidate
LOCIGRAM_CLUSTER_WINDOW_DAYS=30        # lookback window for co-occurrence analysis (days)
LOCIGRAM_DISABLE_INPROCESS_SWEEP=      # set to "true" when using K8s CronJobs (avoids double-run)
